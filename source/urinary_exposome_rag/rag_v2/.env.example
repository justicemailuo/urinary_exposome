# OpenAI-compatible chat endpoint
VLLM_BASE_URL=https://yunwu.ai/v1
VLLM_MODEL=gpt-5.4-nano:stable
VLLM_API_KEY=your_api_token_here

# Retrieval settings
RAG_TOP_K=8
RAG_MAX_CONTEXT_CHARS=2600
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_CHROMA_COLLECTION=urinary_exposome_bge_m3

# Neo4j graph layer
RAG_GRAPH_ENABLED=true
NEO4J_URI=bolt://127.0.0.1:7688
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace_with_a_strong_password
NEO4J_DATABASE=neo4j
NEO4J_WORKSPACE=urological_expomics

# Optional LightRAG context
RAG_LIGHTRAG_ENABLED=false
RAG_LIGHTRAG_MODE=hybrid
RAG_LIGHTRAG_TOP_K=20
